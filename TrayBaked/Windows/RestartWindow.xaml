<Window x:Class="TrayBaked.Windows.RestartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrayBaked"
        Width="480" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        Background="{StaticResource WindowBg}"
        FontFamily="Segoe UI">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- header -->
            <RowDefinition Height="*"/>     <!-- phase panels -->
            <RowDefinition Height="Auto"/>  <!-- footer -->
        </Grid.RowDefinitions>

        <!-- ── Header ────────────────────────────────────────────────────── -->
        <Border Grid.Row="0"
                Background="{StaticResource HeaderBg}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,12">
            <StackPanel Orientation="Horizontal">
                <Image x:Name="HeaderIcon" Width="32" Height="32"
                       Margin="0,0,12,0" VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="TrayBaked"
                               FontSize="16" FontWeight="SemiBold"/>
                    <TextBlock x:Name="HeaderSubtitle"
                               Text="Explorer restarted"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondary}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ── Phase 1: app selection ─────────────────────────────────────── -->
        <Grid Grid.Row="1" x:Name="Phase1Panel" Margin="16,12,16,8">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       Text="Select applications to restart:"
                       Margin="0,0,0,8"/>

            <ListBox Grid.Row="1" x:Name="AppCheckList">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <CheckBox IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                  Content="{Binding DisplayLabel}"
                                  Padding="4,2"/>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <!-- ── Phase 2: progress view ─────────────────────────────────────── -->
        <ListView Grid.Row="1"
                  x:Name="Phase2List"
                  Margin="16,12,16,8"
                  Visibility="Collapsed">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Application" Width="220"
                                    DisplayMemberBinding="{Binding AppName}"/>
                    <GridViewColumn Header="Status" Width="200">
                        <GridViewColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                            Margin="6,0,0,0">
                                    <TextBlock x:Name="Icon"
                                               Width="18"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Margin="0,0,5,0"/>
                                    <TextBlock x:Name="StatusLabel"
                                               Text="{Binding StatusText}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextSecondary}"/>
                                </StackPanel>
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Kind}" Value="Success">
                                        <Setter TargetName="Icon"        Property="Text"       Value="✔"/>
                                        <Setter TargetName="Icon"        Property="Foreground" Value="#107C10"/>
                                        <Setter TargetName="StatusLabel" Property="Foreground" Value="#107C10"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Kind}" Value="Error">
                                        <Setter TargetName="Icon"        Property="Text"       Value="⚠"/>
                                        <Setter TargetName="Icon"        Property="Foreground" Value="#C42B1C"/>
                                        <Setter TargetName="StatusLabel" Property="Foreground" Value="#C42B1C"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Kind}" Value="InProgress">
                                        <Setter TargetName="StatusLabel" Property="Foreground"
                                                Value="{DynamicResource TextPrimary}"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </GridViewColumn.CellTemplate>
                    </GridViewColumn>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- ── Footer ────────────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource FooterBg}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <Grid>
                <!-- Phase 1 buttons -->
                <StackPanel x:Name="Phase1Buttons"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Cancel"
                            Margin="0,0,8,0"
                            Click="Cancel_Click"/>
                    <Button Content="Restart"
                            Style="{StaticResource PrimaryButton}"
                            Click="Restart_Click"/>
                </StackPanel>

                <!-- Phase 2 button -->
                <StackPanel x:Name="Phase2Buttons"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            Visibility="Collapsed">
                    <Button x:Name="CloseBtn"
                            Content="Close"
                            Style="{StaticResource PrimaryButton}"
                            IsEnabled="False"
                            Click="CloseBtn_Click"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
