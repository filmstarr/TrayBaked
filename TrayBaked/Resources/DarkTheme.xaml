<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Windows 11 Dark Theme brushes -->

    <SolidColorBrush x:Key="WindowBg"            Color="#1F1F1F"/>
    <SolidColorBrush x:Key="HeaderBg"            Color="#252525"/>
    <SolidColorBrush x:Key="FooterBg"            Color="#252525"/>
    <SolidColorBrush x:Key="SurfaceBrush"        Color="#272727"/>
    <SolidColorBrush x:Key="BorderBrush"         Color="#1a1a1a"/>
    <SolidColorBrush x:Key="TextPrimary"         Color="#E4E4E4"/>
    <SolidColorBrush x:Key="TextSecondary"       Color="#9A9A9A"/>
    <SolidColorBrush x:Key="AccentBrush"         Color="#0078D4"/>
    <SolidColorBrush x:Key="AccentHoverBrush"    Color="#429CE3"/>
    <SolidColorBrush x:Key="AccentPressBrush"    Color="#005BA1"/>
    <SolidColorBrush x:Key="CtrlBg"              Color="#2D2D2D"/>
    <SolidColorBrush x:Key="CtrlHoverBg"         Color="#262626"/>
    <SolidColorBrush x:Key="CtrlPressBg"         Color="#252525"/>
    <SolidColorBrush x:Key="RowSelectedBg"       Color="#1A3A5C"/>
    <SolidColorBrush x:Key="RowHoverBg"          Color="#2A2A2A"/>
    <SolidColorBrush x:Key="GridHeaderBg"        Color="#252525"/>
    <SolidColorBrush x:Key="AlternatingRowBg"    Color="#242424"/>
    <SolidColorBrush x:Key="MenuSurface"         Color="#1F1F1F"/>
    <SolidColorBrush x:Key="DeleteBtnHoverBg"    Color="#3D1C1C"/>
    <SolidColorBrush x:Key="DeleteBtnHoverFg"    Color="#FF8C8C"/>

</ResourceDictionary>
